OPENCLAW_STUDIO_IMAGE=ghcr.io/semolab/openclaw-studio-casaos:studio-2026.3.9-amd64
NODE_ENV=development
HOST=0.0.0.0
PORT=3000

# Required for public bind. Open once with:
# http://<CASAOS_IP>:3000/?access_token=<value>
STUDIO_ACCESS_TOKEN=CHANGE_ME

# Persist Studio settings/runtime DB inside container
OPENCLAW_STATE_DIR=/data

# Optional default gateway URL shown in Studio settings
NEXT_PUBLIC_GATEWAY_URL=ws://localhost:18789
